#: telegnome.appdata.xml.in:31
msgid ""
"TeleGNOME is a program to display teletext pages over the internet, based "
"on image feeds from a variety of broadcasters."
msgstr ""
"TeleGNOME — әртүрлі хабар таратушылардың кескіндеріне негізделген, интернет "
"арқылы телемәтін беттерін көрсетуге арналған бағдарлама."
